# Copy this file to .env and update the values
# PowerShell: Copy-Item .env.example .env
# Bash: cp .env.example .env

# Google Maps API key (needed for map features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Password pepper (keep this the same everywhere for consistency)
PASSWORD_PEPPER=your_strong_password_pepper

# External API (optional)
API_BASE_URL=
AUTH_API_KEY=

# Cloudinary config (optional, for image upload)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=dwrf0xt1x

# Default password for admin/user setup (change if needed)
DEFAULT_USER_PASSWORD=worksmart123